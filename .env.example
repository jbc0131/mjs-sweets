# Copy this file to .env.local for local dev with `vercel dev`.
# In production, set these in the Vercel dashboard:
#   Project → Settings → Environment Variables.
#
# Get all of these from your Square Developer Dashboard:
#   https://developer.squareup.com/apps

# Sandbox or production. Start with sandbox for testing.
SQUARE_ENVIRONMENT=sandbox

# PUBLIC — sent to the browser via /api/config to initialize the SDK
SQUARE_APPLICATION_ID=sandbox-sq0idb-XXXXXXXXXXXXXXXXXXXXXX
SQUARE_LOCATION_ID=LXXXXXXXXXXXXX

# SECRET — only ever read server-side in /api/checkout. Never expose to the client.
SQUARE_ACCESS_TOKEN=EAAAlXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
